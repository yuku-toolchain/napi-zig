{
  "name": "napi-zig-root",
  "workspaces": [
    "cli",
    "docs"
  ],
  "scripts": {
    "type-check": "bun --filter './cli' type-check && tsgo --noEmit -p tests/dts",
    "release": "bumpp -r --commit 'npm %s' --push --tag --yes",
    "lint": "oxlint",
    "format": "oxfmt",
    "build:cli": "bun --filter './cli' build",
    "test": "zig build test && bun test",
    "docs:dev": "bun --filter './docs' dev",
    "docs:build": "bun --filter './docs' build",
    "docs:preview": "bun --filter './docs' preview"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@typescript/native-preview": "^7.0.0-dev.20260407.1",
    "bumpp": "^11.0.1",
    "napi-zig": "workspace:*",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0"
  }
}
