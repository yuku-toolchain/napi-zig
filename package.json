{
  "name": "napi-zig-root",
  "workspaces": [
    "cli"
  ],
  "scripts": {
    "type-check": "bun --filter './cli' type-check",
    "release": "bumpp -r --commit 'npm %s' --push --tag --yes --release 'patch'",
    "lint": "oxlint",
    "format": "oxfmt",
    "build:cli": "bun --filter './cli' build",
    "test": "zig build test && bun run test:example",
    "test:example": "cd example && rm -rf zig-out .zig-cache && napi build && bun verify.ts"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@typescript/native-preview": "^7.0.0-dev.20260407.1",
    "bumpp": "^11.0.1",
    "napi-zig": "workspace:*",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0"
  }
}
