{
  "name": "napi-zig",
  "version": "0.1.16",
  "description": "Build native Node.js addons with Zig",
  "license": "MIT",
  "bin": {
    "napi": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "scripts": {
    "build": "tsgo",
    "type-check": "tsgo --noEmit",
    "release": "bumpp --commit 'npm %s' --push --tag --yes --release 'patch'",
    "lint": "oxlint",
    "format": "oxfmt"
  },
  "dependencies": {
    "cac": "^7.0.0",
    "ora": "^9.3.0",
    "prompts": "^2.4.2",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/prompts": "^2.4.9",
    "@types/semver": "^7.7.1",
    "@typescript/native-preview": "^7.0.0-dev.20260407.1",
    "bumpp": "^11.0.1",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "author": "Arshad Yaseen <arshadpyaseen@gmail.com> (https://arshad.fyi)",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/yuku-toolchain/napi-zig.git"
	},
	"funding": "https://github.com/sponsors/arshad-yaseen",
	"homepage": "https://napi-zig.dev"
}
