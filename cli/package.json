{
  "name": "napi-zig",
  "version": "0.1.3",
  "description": "Build native Node.js addons with Zig",
  "license": "MIT",
  "files": [
    "dist"
  ],
  "bin": {
    "napi": "dist/index.js"
  },
  "scripts": {
    "build": "bunup",
    "dev": "bunup --watch",
    "type-check": "tsc --noEmit",
    "release": "bumpp -r --commit 'npm %s' --push --tag --yes --release 'patch'"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "bumpp": "^11.0.1",
    "bunup": "^0.16.31",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "typescript": ">=4.5.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "type": "module",
  "dependencies": {
    "cac": "^7.0.0",
    "ora": "^9.3.0"
  }
}
